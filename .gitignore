# OpenClaw runtime state (ephemeral; regenerated on demand)
.openclaw/
state/*
# bin-overrides.jsonl is persistent classifier knowledge — auto-heal accumulates
# decisions here; track so a wipe doesn't lose them.
!state/bin-overrides.jsonl

# Daily memory journal — agent-owned, high churn
memory/

# Traces / reports / per-turn token accounting (Phase 2)
traces/
reports/*
!reports/learnings.md
!reports/mistakes.md
turns/

# Backlog — agent-owned high-churn joint task queue
backlog.jsonl

# Eval harness — per-run artifacts (stdout, traces, summaries)
evals/runs/
evals/bench-runs/

# Eval fixture drafts from mistake-to-fixture.sh — needs manual review
# before promotion to evals/fixtures/
evals/fixtures-draft/

# Peer-agent runtime state — queues, logs, transcripts. Source (README,
# config.json, learnings.md, bin/) stays tracked.
peer-agent/inbox/
peer-agent/outbox/
peer-agent/inbox-processed/
peer-agent/transcript.jsonl
peer-agent/checkins.jsonl
peer-agent/redaction-log.jsonl
peer-agent/poll.log
